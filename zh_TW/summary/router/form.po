msgid "// reactive access to URL query strings\n"
msgstr ""

#: src/router/20_form.md:30
msgid "// search stored as ?q=\n"
msgstr ""

#: src/router/20_form.md:31 src/router/20_form.md:37 src/router/20_form.md:57
msgid "\"q\""
msgstr ""

#: src/router/20_form.md:32
msgid "// a resource driven by the search string\n"
msgstr ""

#: src/router/20_form.md:36 src/router/20_form.md:56 src/router/20_form.md:129
#: src/router/20_form.md:152
msgid "\"GET\""
msgstr ""

#: src/router/20_form.md:36 src/router/20_form.md:56 src/router/20_form.md:96
